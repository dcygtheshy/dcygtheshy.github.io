---
import { Icon } from "astro-icon/components";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const news = [
	{
		date: "2026.09",
		tag: "Next",
		text: "预计进入北京电子科技学院读研，研究方向会围绕模型水印、主动授权控制和 AIGC 标识继续展开。",
	},
	{
		date: "2026.06",
		tag: "Update",
		text: "本科毕业，毕业旅行",
	},
	{
		date: "2025.04",
		tag: "Project",
		text: "#new3",
	},
];

const publications = [
	{
		title: "paper1",
		type: "Placeholder",
		status: "Coming soon",
		authors: ["我", "未来的合作者"],
		note: "作者顺序、共同一作和通讯作者信息会在真实论文确定后更新。",
		venue: "暂无接收会议或期刊，等论文被接收后会在这里写清楚。",
		year: "待定",
		abstract:
			"这是一张占位研究成果卡片。未来如果我真的完成了模型水印、模型授权控制或者 AIGC 标识相关工作，这里会用大白话说明这篇文章到底解决了什么问题、方法核心是什么、实验结果靠不靠谱，以及它和已有工作的区别。",
		pipelineSteps: ["问题定义", "方法设计", "实验验证", "论文整理"],
		links: [
			{ label: "Paper", href: "", icon: "fa6-regular:file-lines", disabled: true },
			{ label: "Code", href: "", icon: "fa6-solid:diagram-project", disabled: true },
			{ label: "Notes", href: "/research/", icon: "fa6-solid:link", disabled: false },
		],
	},
	{
		title: "paper2",
		type: "Preprint",
		status: "Draft idea",
		authors: ["我"],
		note: "当前只是研究兴趣占位",
		venue: "暂无接收会议或期刊，未来投稿后更新。",
		year: "待定",
		abstract:
			"我想关注的问题很朴素：AI 生成的内容能不能更容易被识别，模型的能力调用能不能更可控，模型所有者能不能更主动地管理授权边界。后续如果有实验、开源代码或正式论文，会把摘要、链接、图和结果都补到这里。",
		pipelineSteps: ["文献阅读", "威胁模型", "原型实现", "结果展示"],
		links: [
			{ label: "Website", href: "", icon: "fa6-solid:globe", disabled: true },
			{ label: "Dataset", href: "", icon: "fa6-solid:database", disabled: true },
			{ label: "Email", href: "mailto:1633960501@qq.com", icon: "fa6-solid:arrow-up-right-from-square", disabled: false },
		],
	},
];
---

<MainGridLayout
	title="Research"
	description="朱昊的研究动态、研究成果占位、论文链接和未来 pipeline 展示。"
>
	<section class="space-y-8">
		<header class="space-y-3">
			<p class="text-sm font-semibold uppercase text-[var(--primary)]">Research</p>
			<h1 class="text-3xl font-bold text-neutral-900 transition dark:text-neutral-50">研究动态与成果</h1>
		</header>

		<section class="card-base overflow-hidden rounded-lg">
			<div class="flex items-center justify-between gap-3 border-b border-black/10 px-5 py-4 dark:border-white/10">
				<div>
					<p class="text-sm font-semibold uppercase text-[var(--primary)]">News</p>
					<h2 class="mt-1 text-xl font-bold text-neutral-900 dark:text-neutral-50">最近动态</h2>
				</div>
				<a class="btn-regular h-9 gap-2 rounded-lg px-3 text-sm font-semibold" href="/rss.xml" aria-label="Open RSS feed">
					<Icon name="fa6-solid:rss" class="text-sm" />
					RSS
				</a>
			</div>

			<div class="divide-y divide-black/10 dark:divide-white/10">
				{news.map((item) => (
					<div class="grid gap-2 px-5 py-3 text-sm transition hover:bg-black/[0.025] dark:hover:bg-white/[0.04] md:grid-cols-[5.5rem_5.5rem_1fr] md:items-center">
						<time class="font-mono text-neutral-500 dark:text-neutral-400">{item.date}</time>
						<span class="w-fit rounded-md bg-[var(--btn-regular-bg)] px-2 py-1 text-xs font-semibold text-[var(--primary)]">
							{item.tag}
						</span>
						<p class="min-w-0 leading-6 text-neutral-700 dark:text-neutral-300">{item.text}</p>
					</div>
				))}
			</div>
		</section>

		<section class="space-y-4">
			<div class="flex flex-wrap items-end justify-between gap-3">
				<div>
					<p class="text-sm font-semibold uppercase text-[var(--primary)]">Publications</p>
					<h2 class="mt-1 text-2xl font-bold text-neutral-900 dark:text-neutral-50">研究成果</h2>
				</div>
			</div>

			<div class="space-y-5">
				{publications.map((paper) => (
					<article class="card-base overflow-hidden rounded-lg border border-black/10 px-5 py-5 shadow-sm transition dark:border-white/10 md:px-6">
						<div class="space-y-4">
							<div class="space-y-3">
								<h3 class="text-2xl font-semibold leading-snug text-neutral-800 dark:text-neutral-100">
									{paper.title}
								</h3>
								<div class="flex flex-wrap gap-2">
									<span class="rounded-full bg-[var(--btn-regular-bg)] px-3 py-1 text-sm font-semibold text-[var(--primary)]">
										{paper.type}
									</span>
									<span class="rounded-full bg-black/5 px-3 py-1 text-sm font-semibold text-neutral-600 dark:bg-white/10 dark:text-neutral-300">
										{paper.status}
									</span>
								</div>
							</div>

							<div class="space-y-2 text-sm leading-6 text-neutral-600 dark:text-neutral-300">
								<p>
									<span class="font-semibold text-neutral-900 dark:text-neutral-50">作者：</span>
									{paper.authors.join("，")}
								</p>
								<p class="text-neutral-500 dark:text-neutral-400">{paper.note}</p>
								<p>
									<span class="font-semibold text-neutral-900 dark:text-neutral-50">接收：</span>
									{paper.venue}
									<span class="mx-2 text-neutral-400">•</span>
									{paper.year}
								</p>
							</div>

							<p class="max-w-4xl leading-7 text-neutral-700 dark:text-neutral-300">{paper.abstract}</p>

							<div class="rounded-lg border border-dashed border-black/15 bg-black/[0.015] p-4 dark:border-white/15 dark:bg-white/[0.03]">
								<div class="flex flex-wrap items-center gap-3">
									<div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[var(--btn-regular-bg)] text-[var(--primary)]">
										<Icon name="fa6-solid:diagram-project" class="text-xl" />
									</div>
									<div class="min-w-0">
										<p class="font-semibold text-neutral-900 dark:text-neutral-50">Pipeline 图位置</p>
										<p class="text-sm leading-6 text-neutral-500 dark:text-neutral-400">
											以后可以放方法总览图、实验流程图或者系统架构图；现在先保留位置，避免页面显得空。
										</p>
									</div>
								</div>
								<div class="mt-4 grid gap-2 sm:grid-cols-4">
									{paper.pipelineSteps.map((step, index) => (
										<div class="flex min-h-12 items-center justify-center rounded-md bg-white/70 px-3 py-2 text-center text-sm font-medium text-neutral-700 shadow-sm dark:bg-white/10 dark:text-neutral-200">
											<span class="mr-2 font-mono text-xs text-[var(--primary)]">0{index + 1}</span>
											{step}
										</div>
									))}
								</div>
							</div>

							<div class="flex flex-wrap gap-3 pt-1">
								{paper.links.map((link) => (
									link.disabled ? (
										<span class="inline-flex h-9 cursor-not-allowed items-center gap-2 rounded-lg bg-black/5 px-3 text-sm font-semibold text-neutral-400 dark:bg-white/10 dark:text-neutral-500">
											<Icon name={link.icon} class="text-base" />
											{link.label} 待补
										</span>
									) : (
										<a class="btn-regular h-9 gap-2 rounded-lg px-3 text-sm font-semibold" href={link.href}>
											<Icon name={link.icon} class="text-base" />
											{link.label}
										</a>
									)
								))}
							</div>
						</div>
					</article>
				))}
			</div>
		</section>
	</section>
</MainGridLayout>
